---
// src/components/Faq.astro
interface Props {
  ciudad?: string;
}
const { ciudad } = Astro.props;

const faqsBase = [
  {
    pregunta: '¿Cuánto tarda la instalación?',
    respuesta: 'Normalmente una mañana. Voy a tu local, instalo el equipo, configuro tu carta y tus mesas, y formo a tu equipo el mismo día. Esa misma noche ya puedes trabajar con él.',
  },
  {
    pregunta: '¿Funciona si se cae internet?',
    respuesta: 'Sí. El TPV es local: sigue cobrando y enviando comandas a cocina sin conexión. Cuando vuelve internet, todo se sincroniza solo. Tus ventas nunca se paran por el WiFi.',
  },
  {
    pregunta: '¿Cumple con Verifactu y Hacienda?',
    respuesta: 'Sí, Verifactu está incluido de serie: huella encadenada de facturas, registro conforme y QR según la normativa fiscal española. No es un módulo aparte ni un coste extra.',
  },
  {
    pregunta: '¿Tengo que firmar permanencia?',
    respuesta: 'No. Pagas 35 €/mes y cancelas cuando quieras, sin contratos anuales ni penalizaciones. Si el sistema no te sirve, lo dejas.',
  },
  {
    pregunta: '¿Qué pasa si tengo un problema en pleno servicio?',
    respuesta: 'Me llamas directamente a mí. Nada de call centers ni tickets de soporte: hablas con la persona que programó el sistema y conoce tu local.',
  },
  {
    pregunta: '¿Qué incluye el precio de 35 €/mes?',
    respuesta: 'Todo: pedidos en tiempo real, Carta QR, reservas online, KDS de cocina, cierre de caja, Verifactu y todas las actualizaciones. Sin módulos extra ni sorpresas en la factura.',
  },
];

const faqLocal = ciudad
  ? [{
      pregunta: `¿Dais servicio en ${ciudad}?`,
      respuesta: `Sí. Instalo el TPV y doy soporte presencial en ${ciudad} y alrededores. Conozco la hostelería de la zona y estoy disponible cuando me necesites.`,
    }]
  : [];

const faqs = [...faqLocal, ...faqsBase];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.pregunta,
    acceptedAnswer: { '@type': 'Answer', text: f.respuesta },
  })),
};
---

<section id="faq" class="bg-slate-50 py-20 px-4">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-slate-900 mb-4">Preguntas frecuentes</h2>
      <p class="text-slate-500 text-lg">Lo que todo dueño de restaurante quiere saber antes de cambiar de TPV.</p>
    </div>

    <div class="space-y-3">
      {faqs.map((f) => (
        <details class="group bg-white rounded-2xl border border-slate-200 p-5 [&_summary::-webkit-details-marker]:hidden">
          <summary class="flex items-center justify-between cursor-pointer font-semibold text-slate-900 list-none">
            {f.pregunta}
            <svg class="w-5 h-5 text-slate-400 transition-transform group-open:rotate-180 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <p class="text-slate-500 text-sm leading-relaxed mt-3">{f.respuesta}</p>
        </details>
      ))}
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</section>
