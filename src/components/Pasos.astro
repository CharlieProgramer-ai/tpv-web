---
// src/components/Pasos.astro — cómo es empezar con AMJ TPV
const pasos = [
  {
    num: '1',
    titulo: 'Demo de 20 minutos',
    descripcion: 'Videollamada gratuita. Te enseño el sistema con tu carta y tus mesas. Sin compromiso, sin presión.',
    svg: '<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><circle cx="12" cy="10" r="3"/>',
  },
  {
    num: '2',
    titulo: 'Instalación en una mañana',
    descripcion: 'Voy a tu local, instalo en tu equipo, configuro tu carta completa y formo a tu equipo. Esa misma noche ya funciona.',
    svg: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
  },
  {
    num: '3',
    titulo: 'Soporte directo siempre',
    descripcion: 'Me llamas a mí. No a un número de atención al cliente que no conoce tu local. Yo conozco tu carta, tus mesas y tu equipo.',
    svg: '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.55 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9a16 16 0 0 0 6.91 6.91l.75-.73a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>',
  },
];
---

<section class="bg-slate-800 py-16 px-4 border-y border-slate-700">
  <div class="max-w-5xl mx-auto">
    <p class="text-center text-sm font-semibold text-amber-400 uppercase tracking-widest mb-10">Así de fácil es empezar</p>

    <div class="grid sm:grid-cols-3 gap-6 relative">
      <!-- Línea conectora desktop -->
      <div class="hidden sm:block absolute top-6 left-1/6 right-1/6 h-px bg-slate-700 z-0" style="left: 16.666%; right: 16.666%;"></div>

      {pasos.map((p) => (
        <div class="relative flex flex-col items-center text-center z-10">
          <div class="w-12 h-12 rounded-full bg-amber-500 text-slate-900 font-bold text-lg flex items-center justify-center mb-4 shadow-lg shadow-amber-500/30">
            {p.num}
          </div>
          <h3 class="font-bold text-white text-base mb-2">{p.titulo}</h3>
          <p class="text-slate-400 text-sm leading-relaxed">{p.descripcion}</p>
        </div>
      ))}
    </div>
  </div>
</section>
