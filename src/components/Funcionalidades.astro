---
// src/components/Funcionalidades.astro
const features = [
  {
    svg: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
    titulo: 'Pedidos en tiempo real',
    descripcion: 'El camarero toca "enviar" en su Android y la comanda aparece en cocina en segundos. Sin gritos, sin papel, sin olvidos.',
  },
  {
    svg: '<rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="5" y="5" width="3" height="3"/><rect x="16" y="5" width="3" height="3"/><rect x="16" y="16" width="3" height="3"/><rect x="5" y="16" width="3" height="3"/>',
    titulo: 'Carta QR',
    descripcion: 'El cliente escanea el QR de su mesa y pide desde el móvil. Tú apruebas en un clic. Sin apps que descargar, sin comisiones por pedido.',
  },
  {
    svg: '<path d="M6 13.87A4 4 0 0 1 7.41 6a5.11 5.11 0 0 1 1.05-1.54 5 5 0 0 1 7.08 0A5.11 5.11 0 0 1 16.59 6 4 4 0 0 1 18 13.87V21H6Z"/><line x1="6" y1="17" x2="18" y2="17"/><line x1="6" y1="21" x2="18" y2="21"/>',
    titulo: 'KDS de cocina',
    descripcion: 'La pantalla de cocina se actualiza al instante con cada pedido. Aviso sonoro incluido. Menos caos, menos errores, platos que salen en orden.',
  },
  {
    svg: '<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>',
    titulo: 'Reservas online',
    descripcion: 'El cliente reserva a las 2 de la mañana desde su móvil. Tú lo ves en el TPV al día siguiente. Sin llamadas perdidas, sin libros en papel.',
  },
  {
    svg: '<line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>',
    titulo: 'Cierre de caja',
    descripcion: 'Al acabar el turno: efectivo, tarjeta, mixto y división de cuenta — todo cuadrado automáticamente. Sin calculadora, sin errores de arqueo.',
  },
  {
    svg: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>',
    titulo: 'Verifactu incluido',
    descripcion: 'Obligatorio desde 2025. Ya lo llevas de serie: huella encadenada, registro conforme y QR según la ley. Sin módulos adicionales.',
  },
];
---

<section id="funcionalidades" class="bg-slate-800 py-20 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Todo incluido. Sin asteriscos.</h2>
      <p class="text-slate-400 text-lg">Ni un módulo de pago. Ni una función de pago. Todo esto por <span class="text-amber-400 font-bold">35 €/mes</span>.</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {features.map((f) => (
        <div class="bg-slate-900 rounded-2xl border border-slate-700 p-6 hover:border-amber-500/40 hover:shadow-lg hover:shadow-amber-500/5 transition-all group">
          <div class="w-11 h-11 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center text-amber-400 mb-4 group-hover:bg-amber-500/20 transition-colors">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={f.svg} />
          </div>
          <h3 class="font-bold text-white text-base mb-2">{f.titulo}</h3>
          <p class="text-slate-400 text-sm leading-relaxed">{f.descripcion}</p>
        </div>
      ))}
    </div>
  </div>
</section>
