---
// src/components/Precio.astro
const WA_URL = 'https://wa.me/34654535269?text=Hola%2C%20quiero%20una%20demo%20del%20AMJ%20TPV.%20%C2%BFPodemos%20hablar%3F';

const incluidos = [
  'Pedidos en tiempo real desde el móvil del camarero',
  'Carta QR para que el cliente pida desde su móvil',
  'Reservas online 24 h, gestionadas desde el TPV',
  'KDS de cocina con aviso sonoro',
  'Cierre de caja con historial completo',
  'Verifactu — cumplimiento fiscal de serie',
  'Funciona sin internet (modo local)',
  'Soporte directo con el programador',
  'Actualizaciones gratuitas para siempre',
  'Sin permanencia — cancela cuando quieras',
];
---

<section id="precio" class="bg-slate-900 py-20 px-4">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Precio claro, sin letra pequeña</h2>
    <p class="text-slate-400 text-lg mb-10">Lo que ves es lo que pagas. Sin sorpresas en la factura del mes siguiente.</p>

    <div class="bg-slate-800 rounded-3xl border-2 border-amber-500/50 shadow-2xl shadow-amber-500/10 p-8 relative overflow-hidden">
      <div class="absolute -top-24 -right-24 w-64 h-64 bg-amber-500/5 rounded-full blur-3xl pointer-events-none"></div>

      <div class="relative">
        <p class="text-slate-500 text-sm uppercase tracking-widest font-semibold mb-3">Cuota mensual</p>
        <div class="mb-1">
          <span class="text-7xl font-bold text-amber-400">35 €</span>
          <span class="text-slate-400 text-xl">/mes</span>
        </div>
        <p class="text-slate-400 text-sm mb-1">+ instalación única: <strong class="text-slate-300">300 € (pago único)</strong></p>
        <p class="text-slate-600 text-xs mb-2">Incluye visita presencial, configuración completa de tu carta y formación del equipo</p>
        <p class="text-amber-400/90 text-xs font-semibold mb-2">Oferta de lanzamiento: 250 € para los primeros restaurantes</p>
        <p class="text-slate-600 text-xs mb-8">Precios sin IVA · Hardware no incluido</p>

        <ul class="text-left space-y-3 mb-8">
          {incluidos.map((item) => (
            <li class="flex items-start gap-3 text-slate-300 text-sm">
              <svg class="w-5 h-5 text-amber-400 mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              {item}
            </li>
          ))}
        </ul>

        <a
          href={WA_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="block w-full bg-amber-500 text-slate-900 font-bold text-lg px-8 py-4 rounded-xl hover:bg-amber-400 transition-colors text-center"
        >
          Pide una demo gratuita →
        </a>
        <p class="text-slate-600 text-xs text-center mt-3">20 min por videollamada. Sin compromiso.</p>
      </div>
    </div>
  </div>
</section>
