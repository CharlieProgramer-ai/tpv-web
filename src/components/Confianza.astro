---
// src/components/Confianza.astro
const puntos = [
  {
    titulo: 'Hablas con quien lo programa',
    descripcion: 'Cuando algo falla en pleno servicio, me llamas directamente a mí. Nada de call centers ni tickets que tardan días.',
    svg: '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.55 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9a16 16 0 0 0 6.91 6.91l.75-.73a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>',
  },
  {
    titulo: 'Funciona aunque se caiga el WiFi',
    descripcion: 'El TPV es local: sigue cobrando y enviando comandas a cocina sin internet. Cuando vuelve la conexión, todo se sincroniza solo.',
    svg: '<line x1="1" y1="1" x2="23" y2="23"/><path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55"/><path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39"/><path d="M10.71 5.05A16 16 0 0 1 22.56 9"/><path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/>',
  },
  {
    titulo: 'Verifactu de serie, no un parche',
    descripcion: 'Cumple la normativa fiscal española desde el primer día: huella encadenada, registro de facturas y QR conforme a la ley.',
    svg: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/>',
  },
  {
    titulo: 'Sin permanencia, de verdad',
    descripcion: 'Pagas mes a mes. Si no te sirve, lo dejas. Sin contratos de 12 meses ni penalizaciones por marcharte.',
    svg: '<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><polyline points="9 16 11 18 15 14"/>',
  },
];
---

<section class="bg-slate-800 py-20 px-4">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-white mb-4">Por qué fiarte de este TPV</h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">No somos una multinacional con un número de soporte que no coge nadie. Software español, hecho para que tu restaurante no se pare nunca.</p>
    </div>

    <div class="grid sm:grid-cols-2 gap-5">
      {puntos.map((p) => (
        <div class="flex gap-4 items-start bg-slate-900 rounded-2xl p-6 border border-slate-700 hover:border-amber-500/40 transition-colors">
          <div class="flex-shrink-0 w-11 h-11 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center text-amber-400">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={p.svg} />
          </div>
          <div>
            <h3 class="font-semibold text-white text-base mb-1">{p.titulo}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{p.descripcion}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
