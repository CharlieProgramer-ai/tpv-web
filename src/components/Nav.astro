---
// src/components/Nav.astro
const WA_URL = 'https://wa.me/34654535269?text=Hola%2C%20quiero%20una%20demo%20del%20AMJ%20TPV.%20%C2%BFPodemos%20hablar%3F';
---

<header class="sticky top-0 z-50 bg-slate-900/95 backdrop-blur border-b border-slate-800">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 font-bold text-lg text-white">
      <div class="w-8 h-8 rounded-lg bg-amber-500 flex items-center justify-center">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="3" width="20" height="14" rx="2"/>
          <path d="M8 21h8M12 17v4"/>
        </svg>
      </div>
      <span>AMJ <span class="text-amber-400">TPV</span></span>
    </a>

    <!-- Links desktop -->
    <div class="hidden md:flex items-center gap-6 text-sm text-slate-400">
      <a href="/#funcionalidades" class="hover:text-white transition-colors">Funcionalidades</a>
      <a href="/#precio" class="hover:text-white transition-colors">Precio</a>
      <a href="/#faq" class="hover:text-white transition-colors">FAQ</a>
    </div>

    <!-- CTA -->
    <a
      href={WA_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="bg-amber-500 text-slate-900 text-sm font-bold px-4 py-2 rounded-lg hover:bg-amber-400 transition-colors flex items-center gap-2"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
