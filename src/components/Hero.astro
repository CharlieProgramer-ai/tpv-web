---
// src/components/Hero.astro
interface Props {
  ciudad?: string;
}
const { ciudad } = Astro.props;

const WA_URL = 'https://wa.me/34654535269?text=Hola%2C%20quiero%20una%20demo%20del%20AMJ%20TPV.%20%C2%BFPodemos%20hablar%3F';
---

<section class="bg-slate-900 pt-16 pb-20 px-4 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-amber-500/5 via-transparent to-transparent pointer-events-none"></div>

  <div class="max-w-4xl mx-auto text-center relative">
    <div class="inline-flex items-center gap-2 bg-amber-500/10 border border-amber-500/30 text-amber-400 text-sm font-medium px-4 py-1.5 rounded-full mb-8">
      <span class="w-1.5 h-1.5 bg-amber-400 rounded-full animate-pulse"></span>
      {ciudad ? `Instalación presencial en ${ciudad}` : 'Instalación presencial en Alicante y Elche'} · Sin permanencia
    </div>

    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-white leading-tight mb-4">
      Para de pagar<br class="hidden sm:block" /> módulos extra.
    </h1>

    <p class="text-xl sm:text-2xl font-semibold text-amber-400 mb-6 tracking-wide">
      Carta QR · Reservas · KDS · Verifactu — todo por 35 €/mes
    </p>

    <p class="text-lg text-slate-400 mb-10 max-w-2xl mx-auto leading-relaxed">
      Sin contratos anuales. Funciona aunque se caiga el WiFi.
      Cuando algo falla, hablas conmigo directamente — el programador que conoce tu local, no un call center.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={WA_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-amber-500 text-slate-900 font-bold text-lg px-8 py-4 rounded-xl hover:bg-amber-400 transition-colors flex items-center justify-center gap-3 shadow-lg shadow-amber-500/20"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Pide una demo gratuita
      </a>
      <a
        href="#funcionalidades"
        class="text-slate-300 font-semibold text-lg px-8 py-4 rounded-xl border border-slate-700 hover:border-slate-500 hover:text-white transition-colors"
      >
        Ver qué incluye ↓
      </a>
    </div>

    <div class="flex flex-wrap justify-center gap-8 sm:gap-12 mt-12">
      <div class="text-center">
        <div class="text-3xl font-bold text-amber-400">35 €</div>
        <div class="text-sm text-slate-500 mt-1">al mes, todo incluido</div>
      </div>
      <div class="hidden sm:block w-px bg-slate-800"></div>
      <div class="text-center">
        <div class="text-3xl font-bold text-amber-400">0 €</div>
        <div class="text-sm text-slate-500 mt-1">de módulos extra</div>
      </div>
      <div class="hidden sm:block w-px bg-slate-800"></div>
      <div class="text-center">
        <div class="text-3xl font-bold text-amber-400">Sin</div>
        <div class="text-sm text-slate-500 mt-1">contrato anual</div>
      </div>
    </div>
  </div>

  <div class="max-w-5xl mx-auto mt-16">
    <div class="rounded-2xl border border-slate-700 shadow-2xl shadow-black/60 overflow-hidden bg-slate-800">
      <div class="flex items-center gap-1.5 px-4 h-9 bg-slate-900 border-b border-slate-700">
        <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
        <span class="w-3 h-3 rounded-full bg-amber-500/70"></span>
        <span class="w-3 h-3 rounded-full bg-green-500/70"></span>
        <span class="ml-3 text-xs text-slate-500">Plano de sala — pedidos en tiempo real</span>
      </div>
      <img
        src="/screenshots/plano-sala.webp"
        alt="Plano de sala del TPV con mesas ocupadas, tiempos e importe en tiempo real"
        width="1600"
        height="1000"
        loading="eager"
        decoding="async"
        class="w-full h-auto block"
      />
    </div>
    <p class="text-center text-sm text-slate-700 mt-4">Captura real del sistema en funcionamiento.</p>
  </div>
</section>
