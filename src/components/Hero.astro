---
// src/components/Hero.astro
interface Props {
  ciudad?: string;
}
const { ciudad } = Astro.props;

const titulo = ciudad
  ? `El TPV completo para restaurantes en ${ciudad}, por 35 €/mes`
  : 'Todo tu restaurante en un solo TPV. Por 35 €/mes, sin permanencia.';
---

<section class="bg-white pt-16 pb-20 px-4">
  <div class="max-w-4xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 bg-blue-50 text-[#1e40af] text-sm font-medium px-3 py-1 rounded-full mb-6">
      <span class="w-2 h-2 bg-[#1e40af] rounded-full"></span>
      Verifactu incluido · Sin permanencia · Soporte directo
    </div>

    <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 leading-tight mb-6">
      {titulo}
    </h1>

    <p class="text-xl text-slate-500 mb-10 max-w-2xl mx-auto">
      Carta QR, reservas online, KDS de cocina y Verifactu, todo incluido sin módulos extra. Soporte directo de quien lo programa, no un call center.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="#contacto"
        class="bg-[#1e40af] text-white font-semibold text-lg px-8 py-4 rounded-xl hover:bg-[#1e3a8a] transition-colors"
      >
        Pide una demo gratuita
      </a>
      <a
        href="#funcionalidades"
        class="text-slate-700 font-semibold text-lg px-8 py-4 rounded-xl border border-slate-200 hover:bg-slate-50 transition-colors"
      >
        Ver funcionalidades ↓
      </a>
    </div>

    <div class="flex flex-wrap justify-center gap-8 mt-14 text-center">
      <div>
        <div class="text-3xl font-bold text-slate-900">35&nbsp;€</div>
        <div class="text-sm text-slate-500 mt-1">al mes, todo incluido</div>
      </div>
      <div class="hidden sm:block w-px bg-slate-200"></div>
      <div>
        <div class="text-3xl font-bold text-slate-900">0€</div>
        <div class="text-sm text-slate-500 mt-1">de módulos extra</div>
      </div>
      <div class="hidden sm:block w-px bg-slate-200"></div>
      <div>
        <div class="text-3xl font-bold text-slate-900">Sin</div>
        <div class="text-sm text-slate-500 mt-1">contrato anual</div>
      </div>
    </div>
  </div>
</section>
