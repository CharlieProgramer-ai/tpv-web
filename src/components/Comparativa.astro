---
// src/components/Comparativa.astro
// Sin precios de competidores — varían según plan y los verificamos en web oficial
const filas = [
  { concepto: 'Carta QR',              nosotros: '✓ incluido', revo: 'Módulo extra',  agora: 'Módulo extra' },
  { concepto: 'Reservas online',       nosotros: '✓ incluido', revo: 'Módulo extra',  agora: 'No disponible' },
  { concepto: 'KDS de cocina',         nosotros: '✓ incluido', revo: 'Módulo extra',  agora: 'Módulo extra' },
  { concepto: 'Verifactu',             nosotros: '✓ incluido', revo: '✓',             agora: '✓' },
  { concepto: 'Funciona sin internet', nosotros: '✓',          revo: 'Parcial',       agora: 'Parcial' },
  { concepto: 'Sin permanencia',       nosotros: '✓',          revo: '✗ (anual)',     agora: '✗ (anual)' },
  { concepto: 'Soporte directo',       nosotros: '✓ el programador', revo: '✗ call center', agora: '✗ call center' },
];
---

<section class="bg-slate-800 py-20 px-4">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-10">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">¿Por qué AMJ TPV y no los grandes?</h2>
      <p class="text-slate-400 text-lg">Lo que incluyes vs lo que te cobran aparte.</p>
    </div>

    <div class="overflow-x-auto rounded-2xl border border-slate-700">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-slate-700">
            <th class="text-left p-4 font-semibold text-slate-500 w-2/5 bg-slate-900"></th>
            <th class="p-4 font-bold text-amber-400 bg-amber-500/10 text-center border-x border-slate-700">AMJ TPV</th>
            <th class="p-4 font-semibold text-slate-500 text-center bg-slate-900">Revo</th>
            <th class="p-4 font-semibold text-slate-500 text-center bg-slate-900">Ágora</th>
          </tr>
        </thead>
        <tbody>
          {filas.map((fila, i) => (
            <tr class={`border-b border-slate-800 ${i % 2 === 0 ? 'bg-slate-900' : 'bg-slate-900/60'}`}>
              <td class="p-4 text-slate-300 font-medium">{fila.concepto}</td>
              <td class={`p-4 text-center font-semibold bg-amber-500/5 border-x border-slate-700/50 ${fila.nosotros.startsWith('✓') ? 'text-amber-400' : 'text-white'}`}>
                {fila.nosotros}
              </td>
              <td class={`p-4 text-center ${fila.revo.startsWith('✗') || fila.revo.includes('extra') ? 'text-red-400' : 'text-slate-400'}`}>
                {fila.revo}
              </td>
              <td class={`p-4 text-center ${fila.agora.startsWith('✗') || fila.agora.includes('extra') || fila.agora === 'No disponible' ? 'text-red-400' : 'text-slate-400'}`}>
                {fila.agora}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="text-xs text-slate-600 mt-3 text-center">* Información basada en los planes publicados por cada proveedor. Consulta su web para precios actualizados.</p>
  </div>
</section>
