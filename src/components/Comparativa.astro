---
// src/components/Comparativa.astro
// Precios de competidores son aproximados (consultados junio 2026)
const filas = [
  { concepto: 'Precio mensual',        nosotros: '35 €/mes',   revo: '~79 €/mes',    agora: '~89 €/mes' },
  { concepto: 'Carta QR',              nosotros: '✓ incluido', revo: 'Módulo extra',  agora: 'Módulo extra' },
  { concepto: 'Reservas online',       nosotros: '✓ incluido', revo: 'Módulo extra',  agora: 'No disponible' },
  { concepto: 'KDS de cocina',         nosotros: '✓ incluido', revo: 'Módulo extra',  agora: 'Módulo extra' },
  { concepto: 'Verifactu',             nosotros: '✓ incluido', revo: '✓',             agora: '✓' },
  { concepto: 'Sin permanencia',       nosotros: '✓',          revo: '✗ (anual)',     agora: '✗ (anual)' },
  { concepto: 'Soporte directo',       nosotros: '✓',          revo: '✗ call center', agora: '✗ call center' },
  { concepto: 'Funciona sin internet', nosotros: '✓',          revo: 'Parcial',       agora: 'Parcial' },
];
---

<section class="bg-white py-20 px-4">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-10">
      <h2 class="text-3xl font-bold text-slate-900 mb-4">¿Por qué elegirnos?</h2>
      <p class="text-slate-500 text-lg">Comparado con las alternativas del mercado.</p>
    </div>

    <div class="overflow-x-auto rounded-2xl border border-slate-200">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-slate-200">
            <th class="text-left p-4 font-semibold text-slate-600 w-1/3"></th>
            <th class="p-4 font-bold text-[#1e40af] bg-blue-50 text-center">AMJ TPV</th>
            <th class="p-4 font-semibold text-slate-500 text-center">Revo</th>
            <th class="p-4 font-semibold text-slate-500 text-center">Ágora</th>
          </tr>
        </thead>
        <tbody>
          {filas.map((fila, i) => (
            <tr class={`border-b border-slate-100 ${i % 2 === 0 ? '' : 'bg-slate-50'}`}>
              <td class="p-4 text-slate-700 font-medium">{fila.concepto}</td>
              <td class={`p-4 text-center font-semibold bg-blue-50 ${fila.nosotros.startsWith('✓') ? 'text-[#1e40af]' : 'text-slate-900'}`}>
                {fila.nosotros}
              </td>
              <td class={`p-4 text-center ${fila.revo.startsWith('✗') || fila.revo.includes('extra') ? 'text-red-500' : 'text-slate-600'}`}>
                {fila.revo}
              </td>
              <td class={`p-4 text-center ${fila.agora.startsWith('✗') || fila.agora.includes('extra') || fila.agora === 'No disponible' ? 'text-red-500' : 'text-slate-600'}`}>
                {fila.agora}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="text-xs text-slate-400 mt-3 text-center">* Precios de competidores aproximados. Consultados junio 2026.</p>
  </div>
</section>
