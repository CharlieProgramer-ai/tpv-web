---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Confianza from '../components/Confianza.astro';
import Problema from '../components/Problema.astro';
import Funcionalidades from '../components/Funcionalidades.astro';
import Precio from '../components/Precio.astro';
import Comparativa from '../components/Comparativa.astro';
import Faq from '../components/Faq.astro';
import Contacto from '../components/Contacto.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="TPV para restaurantes — Todo incluido desde 35 €/mes | TPV Restaurante"
  description="Software TPV para restaurantes con Carta QR, reservas online, KDS y Verifactu incluidos. Sin módulos extra, sin contratos anuales. Desde 35 €/mes con soporte directo."
  localBusiness={true}
>
  <Nav />
  <main>
    <Hero />
    <Confianza />
    <Problema />
    <Funcionalidades />
    <Precio />
    <Comparativa />
    <Faq />
    <Contacto />
  </main>
  <Footer />
</Layout>
