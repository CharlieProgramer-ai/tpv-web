---
// src/pages/gracias.astro
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Solicitud recibida — AMJ TPV"
  description="Hemos recibido tu solicitud. Te contactaremos en menos de 24 horas."
  noindex={true}
>
  <Nav />
  <main class="min-h-[60vh] flex items-center justify-center px-4 py-20">
    <div class="text-center max-w-md">
      <div class="text-5xl mb-6">✅</div>
      <h1 class="text-3xl font-bold text-slate-900 mb-4">¡Solicitud recibida!</h1>
      <p class="text-slate-500 text-lg mb-8">
        Te contactaré en menos de 24 horas para confirmar la demo. Si prefieres escribir ahora,
        <a href="https://wa.me/34654535269" class="text-[#1e40af] underline">escríbeme por WhatsApp</a>.
      </p>
      <a href="/" class="text-[#1e40af] font-semibold hover:underline">← Volver al inicio</a>
    </div>
  </main>
  <Footer />
</Layout>
